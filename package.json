{
  "name": "takai-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "expo": "~54.0.35",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "tsx": "^4.23.1",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck",
    "test": "npm run typecheck && npm run test:domain && npm run test:operations",
    "test:domain": "tsx scripts/domain-schema-check.ts",
    "test:operations": "tsx scripts/operational-slice-check.ts",
    "test:design-contract": "node scripts/design-contract-check.mjs",
    "test:expo-go-compat": "node scripts/expo-go-compat-check.mjs"
